# Qwen API 配置（OpenAI 兼容模式）
# 复制此文件为 .env 并填入你的 API Key

# Qwen API Key（必填）
QWEN_API_KEY=your_api_key_here

# Qwen API Base（中国区）
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# 模型名称（可选，默认 qwen3.5-plus）
QWEN_MODEL=qwen3.5-plus

# Qwen Realtime TTS（可选，默认中国区）
DASHSCOPE_API_KEY=your_api_key_here
DASHSCOPE_REALTIME_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
QWEN_TTS_REALTIME_URL=
QWEN_TTS_MODEL=qwen3-tts-instruct-flash-realtime
QWEN_TTS_VOICE=Cherry
QWEN_TTS_INSTRUCTIONS=请用卡通、可爱、活泼的童声风格朗读，语速适中，语气友好自然。

# Qwen Realtime ASR（语音转文字）
QWEN_ASR_REALTIME_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
QWEN_ASR_MODEL=qwen3-asr-flash-realtime
QWEN_ASR_LANGUAGE=zh
